{
  "name": "cognipace-extension",
  "version": "0.1.0",
  "private": true,
  "description": "CogniPace Chrome extension for deliberate interview practice",
  "scripts": {
    "build": "node build.cjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "npm run test:logic && npm run test:ui",
    "typecheck": "tsc --noEmit",
    "test:logic": "node tests/run-tests.cjs",
    "test:ui": "vitest run"
  },
  "keywords": [
    "chrome-extension",
    "cognipace",
    "leetcode",
    "spaced-repetition"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.36",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-fsrs": "^5.3.1"
  }
}
